{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Mintie SSO",
  "description": "Enterprise SSO, SCIM, and identity for Mintie",
  "colors": {
    "primary": "#0C8C5E",
    "light": "#0C8C5E",
    "dark": "#0C8C5E"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "aistudio",
      "devin",
      "windsurf",
      "mcp",
      "cursor",
      "vscode",
      "devin-mcp"
    ]
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "App Catalog",
        "groups": [
          {
            "group": "Catalog",
            "pages": ["catalog", "catalog-submit", "catalog-new-version"]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@mintie.example"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintie.example"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintie",
      "github": "https://github.com/mintie"
    }
  },
  "seo": {
    "metatags": {
      "robots": "noindex"
    }
  }
}
